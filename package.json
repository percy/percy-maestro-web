{
  "name": "@percy/maestro",
  "description": "Maestro client library for visual testing with Percy",
  "version": "0.1.0-alpha.0",
  "license": "MIT",
  "author": "Perceptual Inc.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/percy/percy-maestro.git"
  },
  "keywords": [
    "maestro",
    "percy",
    "visual testing",
    "mobile testing"
  ],
  "main": "index.js",
  "types": "types/index.d.ts",
  "bin": {
    "percy-maestro": "./percy/cli.js"
  },
  "files": [
    "index.js",
    "types/index.d.ts",
    "percy",
    "scripts"
  ],
  "engines": {
    "node": ">=14"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "scripts": {
    "lint": "eslint --ignore-path .gitignore .",
    "test": "cross-env NODE_ENV=test jasmine --config=./test/jasmine.json",
    "test:coverage": "nyc yarn test"
  },
  "dependencies": {
    "@percy/dom": "^1.30.9",
    "@percy/sdk-utils": "^1.30.9",
    "chrome-remote-interface": "^0.34.0",
    "commander": "^11.1.0",
    "tmp": "^0.2.3"
  },
  "devDependencies": {
    "@percy/cli": "^1.30.9",
    "cross-env": "^7.0.2",
    "eslint": "^8.27.0",
    "eslint-plugin-n": "^15.5.1",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-promise": "^6.1.1",
    "jasmine": "^5.4.0",
    "jasmine-spec-reporter": "^7.0.0",
    "nyc": "^15.1.0"
  },
  "bugs": {
    "url": "https://github.com/percy/percy-maestro/issues"
  },
  "homepage": "https://github.com/percy/percy-maestro#readme"
}
